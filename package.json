{
  "name": "head-terminal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "start:dev": "bash scripts/head-terminal-dev.sh",
    "start:dev:watch": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "build:dev": "npm run build && tauri build --debug --no-bundle --config src-tauri/tauri.dev.conf.json && cp src-tauri/target/debug/head-terminal src-tauri/target/debug/head-terminal-dev",
    "build:release": "npm run build && tauri build --no-bundle",
    "build:release:deb": "npm run build && tauri build --bundles deb",
    "start:prod": "bash scripts/head-terminal-release.sh",
    "install:desktop": "bash scripts/install-desktop-entry.sh",
    "install:desktop:release": "bash scripts/install-desktop-entry.sh --release"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tauri-pty": "^0.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
